{
  "name": "poker-diary",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"node server/index.js\" \"vite\"",
    "dev:electron": "concurrently -k \"node server/index.js\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build && electron-builder build --win",
    "preview": "vite preview",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "antd": "^5.22.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.8.3",
    "i18next": "^26.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
