  "faq": {
    "page": {
      "title": "FAQ — Как это работает"
    },
    "room": {
      "label": "🏠 Рум — что это?",
      "content": "Рум — это покерная комната (PokerStars, GG Poker, CoinPoker и т.д.). Все турниры группируются по румам. Вы можете добавлять, редактировать и удалять румы на странице «Турниры»."
    },
    "tournament": {
      "label": "🏆 Турнир — как добавить?",
      "content": "На странице «Турниры» выберите рум и нажмите «Добавить турнир». Укажите название, бай-ин и валюту. После создания турнир появится в списке доступных для новой сессии."
    },
    "session": {
      "label": "🎮 Игровая сессия — что это?",
      "content": "Сессия — это один сыгранный турнир. На странице «Игровые сессии» нажмите «Начать турнир», выберите рум, турнир, укажите бэкера (если их несколько) и сохраните. После сохранения сессия появится в таблице с сортировкой по колонкам и пагинацией (по умолчанию 20 строк). В таблице можно редактировать поля (бэкинг, место, выигрыш, баунти) прямо в строке."
    },
    "finish": {
      "label": "✅ Завершить сессию — зачем?",
      "content": "Если вы начали турнир, но не заполнили результат — нажмите «Завершить сессию». Все незавершённые сессии за сегодня будут отмечены как сыгранные без выигрыша и уберутся из блока «Сегодня». Их можно найти через календарь, выбрав эту дату."
    },
    "bankroll": {
      "label": "💰 Банкролл — как работает?",
      "content": "Банкролл автоматически считает баланс для каждого рума: профит с турниров + ручные операции. Вы можете пополнить (+) или снять (-) средства в любой валюте (USD/EUR/RUB). Курсы валют редактируются вручную или загружаются из интернета (кнопка обновления). Для каждого рума можно выбрать валюту отображения (USD/EUR/RUB) кнопками внизу карточки. Операции «Оплата бэкером» не влияют на баланс рума — они отображаются только в истории."
    },
    "reports": {
      "label": "📊 Отчёты — что там?",
      "intro": "На странице «Отчёты» собраны диаграммы и статистика:",
      "list": {
        "profitByRoom": "Профит по румам",
        "profitByRoomDesc": "круговая диаграмма",
        "profitByTournament": "Профит по турнирам",
        "profitByTournamentDesc": "столбцы (прибыль по каждому турниру)",
        "bankroll": "Банкролл",
        "bankrollDesc": "линия нарастающего итога",
        "expenses": "Расходы",
        "expensesDesc": "статистика: сыграно турниров, общие бай-ины, итого выиграно, ТОП-10 худших турниров"
      },
      "footer": "Сверху можно выбрать валюту для отображения, отфильтровать по руму и по турнирам."
    },
    "currencies": {
      "label": "💱 Валюты — как настроить?",
      "content": "В приложении три валюты: USD, EUR, RUB. Все суммы в базе хранятся в USD. Курсы задаются на странице «Банкролл». Вы можете ввести их вручную или нажать кнопку обновления для загрузки актуальных курсов с exchangerate-api.com. Курсы сохраняются в localStorage и не сбрасываются при перезагрузке. Для каждого рума можно выбрать валюту отображения (USD/EUR/RUB) — баланс будет показан в RUB и EUR по текущим курсам, а основное значение остаётся в USD."
    },
    "backing": {
      "label": "🧑‍💼 Бэкинг — как работает?",
      "intro": "На странице «Бэкер» можно управлять бэкерами (инвесторами), которые финансируют ваши турниры.",
      "list": {
        "add": "Добавление бэкеров",
        "addDesc": "укажите имя и процент от профита. Можно добавить нескольких бэкеров с разными процентами.",
        "link": "Привязка к сессиям",
        "linkDesc": "при создании сессии выберите бэкера (если их несколько). Если бэкер один — он подставляется автоматически.",
        "ops": "Операции",
        "opsDesc": "\"Получить\" (бэкер перевёл деньги), \"Выплатить\" (вы переводите бэкеру), \"Выплата из собственных средств\" (бэкер оплатил турнир напрямую — не влияет на баланс рума).",
        "debt": "Долг",
        "debtDesc": "автоматически рассчитывается: доля бэкера + получено - выплачено - оплачено бэкером.",
        "history": "История",
        "historyDesc": "все операции с фильтром по руму и дате, возможность редактирования и удаления."
      }
    },
    "movements": {
      "label": "🔄 Движение средств — что это?",
      "intro": "Страница «Движение средств» показывает все финансовые операции в хронологическом порядке:",
      "list": {
        "wins": "Выигрыши и Проигрыши",
